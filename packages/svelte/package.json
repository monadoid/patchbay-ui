{
  "name": "@patchbayhq/svelte",
  "version": "0.1.2",
  "description": "Svelte wrappers for patchbay UI audio controls.",
  "license": "MIT",
  "type": "module",
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "homepage": "https://ui.patchbay.tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monadoid/patchbay-ui.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/monadoid/patchbay-ui/issues"
  },
  "keywords": [
    "audio",
    "controls",
    "svelte",
    "ui"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": [
    "./src/styles.css",
    "./src/tailwind.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tailwind.css": "./src/tailwind.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check-types": "svelte-check --tsconfig tsconfig.json"
  },
  "dependencies": {
    "@patchbayhq/ui": "^0.1.2"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0"
  }
}
