{
  "name": "@patchbayhq/react",
  "version": "0.1.1",
  "description": "React wrappers for patchbay UI audio controls.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://ui.patchbay.tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monadoid/patchbay-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/monadoid/patchbay-ui/issues"
  },
  "keywords": [
    "audio",
    "controls",
    "react",
    "ui"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "./dist/tailwind.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind.css": "./dist/tailwind.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist .cache/tsbuildinfo.build.json && tsc -p tsconfig.build.json && cp src/styles.css src/tailwind.css dist/",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@patchbayhq/ui": "^0.1.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
