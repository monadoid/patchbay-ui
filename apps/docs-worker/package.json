{
  "name": "@patchbay/docs-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "vite build",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "vite build && wrangler dev --host 127.0.0.1 --port 7011",
    "dev:preview": "vite build && wrangler dev --host 127.0.0.1 --port 7014",
