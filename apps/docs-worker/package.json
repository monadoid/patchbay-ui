    "start": "vite build && wrangler dev --host 127.0.0.1 --port 7011"
  },
  "dependencies": {
    "@patchbay/svelte": "workspace:*",
    "@patchbay/ui": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "lucide-svelte": "^1.0.1",
    "shiki": "^4.2.0",
    "svelte": "^5.56.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "svelte-check": "^4.6.0",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  }
