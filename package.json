{
  "name": "patchbay-ui",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp dev apps/pb-ui-lab --host 127.0.0.1 --port 7010",
    "dev:docs": "vp run --filter @patchbayhq/docs-worker dev",
    "dev:docs:preview": "vp run --filter @patchbayhq/docs-worker dev:preview",
    "build": "pnpm --filter @patchbayhq/ui build && pnpm --filter @patchbayhq/react build && pnpm --filter @patchbayhq/lab build && pnpm --filter @patchbayhq/docs-worker build",
    "build:docs": "vp run --filter @patchbayhq/docs-worker build",
    "build:lab": "vp run --filter @patchbayhq/lab build",
    "changeset": "changeset",
    "check-types": "vp run -r check-types",
    "release:npm": "node scripts/publish-npm.mjs",
    "test": "vp run --filter @patchbayhq/ui test",
    "test:browser": "vp run --filter @patchbayhq/lab test:browser",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.10.1",
    "@vitest/browser-playwright": "^4.1.8",
    "playwright": "^1.60.0",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@10.25.0"
}
